<launch>

  <!-- Set ROS master URI -->
  <arg name="master_uri" default="http://10.178.1.98:11311"/>
  <env name="ROS_MASTER_URI" value="$(arg master_uri)" />

  <!-- Launch Vision_node -->
  <node
    pkg="quori_interactions"
    type="virtual_joy_2.py"
    name="Virtual_Joystick"
    output="screen"
  />

  <!-- Launch MovementControl -->
  <node
    pkg="quori_interactions"
    type="movement_control.py"
    name="movement_control_node"
    output="screen"
  />

</launch>

